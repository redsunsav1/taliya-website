<div class="callback-form-wrapper fade-in">
  <h2 class="section__title">Запишитесь на консультацию</h2>
  <p class="section__subtitle">Наши специалисты ответят на все ваши вопросы</p>

  <form id="callbackForm" class="callback-form" method="POST" action="/callback">
    <div class="form-group">
      <label for="callback-name" class="form-label">
        Ваше имя <span class="required">*</span>
      </label>
      <input 
        type="text" 
        id="callback-name" 
        name="name" 
        class="form-input" 
        placeholder="Введите ваше имя"
        required
        minlength="2"
      >
      <span class="form-error" id="error-name"></span>
    </div>

    <div class="form-group">
      <label for="callback-phone" class="form-label">
        Номер телефона <span class="required">*</span>
      </label>
      <input 
        type="tel" 
        id="callback-phone" 
        name="phone" 
        class="form-input" 
        placeholder="+7 (___) ___-__-__"
        required
        pattern="[0-9+\s\-\(\)]{10,}"
      >
      <span class="form-error" id="error-phone"></span>
    </div>

    <div class="form-group">
      <label for="callback-email" class="form-label">
        Адрес электронной почты
      </label>
      <input 
        type="email" 
        id="callback-email" 
        name="email" 
        class="form-input" 
        placeholder="имя@почта.ру"
      >
      <span class="form-error" id="error-email"></span>
    </div>

    <% if (content.services && Array.isArray(content.services)) { %>
      <div class="form-group">
        <label for="callback-service" class="form-label">
          Интересующая услуга
        </label>
        <select id="callback-service" name="service" class="form-select">
          <option value="">Выберите услугу</option>
          <% content.services.forEach(function(service) { %>
            <option value="<%= service.id || service.name %>"><%= service.name %></option>
          <% }); %>
        </select>
      </div>
    <% } %>

    <div class="form-group">
      <label for="callback-message" class="form-label">
        Сообщение
      </label>
      <textarea 
        id="callback-message" 
        name="message" 
        class="form-textarea" 
        placeholder="Расскажите о ваших пожеланиях и вопросах"
        rows="4"
        maxlength="1000"
      ></textarea>
      <span class="form-hint"><span id="message-length">0</span>/1000</span>
    </div>

    <div class="form-group form-group--checkbox">
      <div class="checkbox-wrapper">
        <input 
          type="checkbox" 
          id="callback-consent" 
          name="consent" 
          class="form-checkbox" 
          required
        >
        <label for="callback-consent" class="checkbox-label">
          Нажимая кнопку «Отправить», я даю согласие на обработку персональных данных согласно 
          <a href="/consent" target="_blank" class="link-inline">Политике конфиденциальности</a>
        </label>
      </div>
      <span class="form-error" id="error-consent"></span>
    </div>

    <input type="hidden" name="pageSource" id="page-source" value="">

    <button type="submit" class="btn btn--primary btn--large callback-submit">
      <i class="lucide" data-icon="send"></i>
      Отправить
    </button>

    <div class="form-message form-message--success" id="successMessage" style="display: none;">
      <div class="message-content">
        <i class="lucide" data-icon="check-circle"></i>
        <div>
          <strong>Спасибо!</strong>
          <p>Ваше сообщение отправлено. Мы свяжемся с вами в ближайшее время.</p>
        </div>
      </div>
    </div>

    <div class="form-message form-message--error" id="errorMessage" style="display: none;">
      <div class="message-content">
        <i class="lucide" data-icon="alert-circle"></i>
        <div>
          <strong>Ошибка!</strong>
          <p id="errorMessageText">При отправке произошла ошибка. Попробуйте еще раз.</p>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('callbackForm');
    const pageSource = document.getElementById('page-source');
    const messageLength = document.getElementById('message-length');
    const successMessage = document.getElementById('successMessage');
    const errorMessage = document.getElementById('errorMessage');
    const textarea = document.getElementById('callback-message');

    // Устанавливаем источник страницы
    pageSource.value = document.title || 'Неизвестная страница';

    // Счетчик символов в сообщении
    if (textarea) {
      textarea.addEventListener('input', function() {
        messageLength.textContent = this.value.length;
      });
    }

    // Отправка формы через AJAX
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      // Очищаем предыдущие сообщения об ошибках
      document.querySelectorAll('.form-error').forEach(el => el.textContent = '');
      successMessage.style.display = 'none';
      errorMessage.style.display = 'none';

      // Собираем данные формы
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        // Отправляем данные на сервер
        const response = await fetch('/callback', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Показываем сообщение об успехе
          successMessage.style.display = 'flex';
          form.reset();
          messageLength.textContent = '0';

          // Скрываем сообщение через 5 секунд
          setTimeout(() => {
            successMessage.style.display = 'none';
          }, 5000);
        } else {
          // Обработка ошибок валидации
          if (result.errors) {
            Object.keys(result.errors).forEach(field => {
              const errorElement = document.getElementById(`error-${field}`);
              if (errorElement) {
                errorElement.textContent = result.errors[field];
              }
            });
          }
          
          // Показываем общее сообщение об ошибке
          document.getElementById('errorMessageText').textContent = 
            result.message || 'При отправке произошла ошибка. Попробуйте еще раз.';
          errorMessage.style.display = 'flex';
        }
      } catch (error) {
        console.error('Ошибка при отправке формы:', error);
        document.getElementById('errorMessageText').textContent = 
          'При отправке произошла ошибка сети. Проверьте соединение и попробуйте еще раз.';
        errorMessage.style.display = 'flex';
      }
    });

    // Телефонная маска
    const phoneInput = document.getElementById('callback-phone');
    if (phoneInput) {
      phoneInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        
        if (value.length > 0) {
          if (value[0] !== '7' && value[0] !== '8') {
            value = '7' + value;
          }
          
          if (value.length > 1) {
            value = '+' + value[0] + ' (' + value.slice(1, 4);
          }
          if (value.length > 8) {
            value = value.slice(0, 8) + ') ' + value.slice(8, 11);
          }
          if (value.length > 12) {
            value = value.slice(0, 12) + '-' + value.slice(12, 14);
          }
          if (value.length > 15) {
            value = value.slice(0, 15) + '-' + value.slice(15, 17);
          }
          
          e.target.value = value;
        }
      });
    }
  });
</script>
