<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Разделы услуг — <%= content.site.name %> Админ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Montserrat', sans-serif; background: #f5f1ee; color: #333; min-height: 100vh; }

    .admin-layout { display: flex; min-height: 100vh; }

    .admin-sidebar {
      width: 260px;
      background: linear-gradient(180deg, #596341 0%, #454d33 100%);
      color: #fff; flex-shrink: 0; position: fixed;
      top: 0; left: 0; bottom: 0; overflow-y: auto; z-index: 100;
    }
    .admin-sidebar__brand { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.15); }
    .admin-sidebar__brand-name { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 600; display: block; }
    .admin-sidebar__brand-sub { font-size: 0.7rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; display: block; }
    .admin-sidebar__nav { padding: 16px 0; }
    .admin-sidebar__link {
      display: flex; align-items: center; gap: 10px; padding: 12px 24px;
      color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.88rem;
      font-weight: 500; transition: all 0.2s; border-left: 3px solid transparent;
    }
    .admin-sidebar__link:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .admin-sidebar__link--active { background: rgba(255,255,255,0.12); color: #fff; border-left-color: #fff; }
    .admin-sidebar__link--danger { color: rgba(255,200,200,0.8); }
    .admin-sidebar__link--danger:hover { color: #fcc; background: rgba(255,100,100,0.15); }
    .admin-sidebar__separator { height: 1px; background: rgba(255,255,255,0.12); margin: 8px 24px; }
    .admin-sidebar__link-icon { width: 18px; text-align: center; font-style: normal; }

    .admin-content { flex: 1; margin-left: 260px; padding: 32px 40px; min-height: 100vh; }
    .admin-content__header { margin-bottom: 32px; }
    .admin-content__breadcrumb { font-size: 0.78rem; color: #999; margin-bottom: 6px; }
    .admin-content__breadcrumb a { color: #596341; text-decoration: none; }
    .admin-content__breadcrumb a:hover { text-decoration: underline; }
    .admin-content__title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 600; color: #333; }

    .admin-card {
      background: #fff; border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06); padding: 28px; margin-bottom: 24px;
    }
    .admin-card__title { font-size: 1rem; font-weight: 600; color: #555; margin-bottom: 16px; }

    .admin-form__group { margin-bottom: 20px; }
    .admin-form__label {
      display: block; font-size: 0.8rem; font-weight: 600; color: #555;
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .admin-form__input {
      width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px;
      font-size: 0.9rem; font-family: 'Montserrat', sans-serif; transition: border-color 0.2s;
    }
    .admin-form__input:focus {
      outline: none; border-color: #596341; box-shadow: 0 0 0 3px rgba(89,99,65,0.1);
    }
    .admin-form__hint { font-size: 0.75rem; color: #aaa; margin-top: 4px; }

    .admin-form__btn {
      display: inline-block; padding: 12px 32px; background: #596341; color: #fff;
      border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 600;
      font-family: 'Montserrat', sans-serif; cursor: pointer; transition: background 0.2s;
    }
    .admin-form__btn:hover { background: #7a4f5c; }

    .admin-form__btn--small {
      padding: 8px 18px; font-size: 0.82rem;
    }

    .admin-alert {
      padding: 12px 20px; border-radius: 8px; margin-bottom: 24px; font-size: 0.88rem;
    }
    .admin-alert--success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }

    /* Services table */
    .admin-table {
      width: 100%;
      border-collapse: collapse;
    }
    .admin-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 700;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 10px 14px;
      border-bottom: 2px solid #eee;
    }
    .admin-table td {
      padding: 14px;
      border-bottom: 1px solid #f0f0f0;
      font-size: 0.88rem;
      vertical-align: middle;
    }
    .admin-table tr:last-child td {
      border-bottom: none;
    }
    .admin-table tr:hover td {
      background: #faf8f7;
    }
    .admin-table__name {
      font-weight: 600;
      color: #333;
    }
    .admin-table__short {
      font-size: 0.8rem;
      color: #999;
    }
    .admin-table__count {
      display: inline-block;
      background: #f3e8f4;
      color: #596341;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .admin-table__actions {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .admin-table__btn {
      display: inline-block;
      padding: 6px 14px;
      border-radius: 6px;
      font-size: 0.78rem;
      font-weight: 600;
      font-family: 'Montserrat', sans-serif;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }
    .admin-table__btn--edit {
      background: #f0f0f0;
      color: #555;
    }
    .admin-table__btn--edit:hover {
      background: #596341;
      color: #fff;
    }
    .admin-table__btn--delete {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
    }
    .admin-table__btn--delete:hover {
      background: #b91c1c;
      color: #fff;
    }
    .admin-table__btn--reorder {
      background: #f0f9f0;
      color: #16a34a;
      border: 1px solid #86efac;
      padding: 6px 10px;
    }
    .admin-table__btn--reorder:hover {
      background: #16a34a;
      color: #fff;
    }
    .admin-table__btn--reorder:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Add service form */
    .admin-form__row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }

    @media (max-width: 768px) {
      .admin-sidebar { width: 220px; }
      .admin-content { margin-left: 220px; padding: 24px 20px; }
      .admin-form__row { grid-template-columns: 1fr; }
      .admin-table { font-size: 0.82rem; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar__brand">
        <span class="admin-sidebar__brand-name"><%= content.site.name %></span>
        <span class="admin-sidebar__brand-sub">Админ-панель</span>
      </div>
      <nav class="admin-sidebar__nav">
        <a href="/admin" class="admin-sidebar__link">
          <span class="admin-sidebar__link-icon">&#9776;</span> Главная панель
        </a>
        <a href="/admin/settings" class="admin-sidebar__link">
          <span class="admin-sidebar__link-icon">&#9881;</span> Настройки сайта
        </a>
        <a href="/admin/hero" class="admin-sidebar__link">
          <span class="admin-sidebar__link-icon">&#9733;</span> Главный экран
        </a>
        <a href="/admin/benefits" class="admin-sidebar__link">
          <span class="admin-sidebar__link-icon">&#10004;</span> Преимущества
        </a>
        <a href="/admin/services" class="admin-sidebar__link admin-sidebar__link--active">
          <span class="admin-sidebar__link-icon">&#9998;</span> Разделы услуг
        </a>
        <div class="admin-sidebar__separator"></div>
        <a href="/admin/password" class="admin-sidebar__link">
          <span class="admin-sidebar__link-icon">&#128274;</span> Сменить пароль
        </a>
        <a href="/admin/logout" class="admin-sidebar__link admin-sidebar__link--danger">
          <span class="admin-sidebar__link-icon">&#10140;</span> Выход
        </a>
        <div class="admin-sidebar__separator"></div>
        <a href="/" class="admin-sidebar__link" target="_blank">
          <span class="admin-sidebar__link-icon">&#127760;</span> Вернуться на сайт
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
      <div class="admin-content__header">
        <div class="admin-content__breadcrumb">
          <a href="/admin">Админ-панель</a> / Разделы услуг
        </div>
        <h1 class="admin-content__title">Разделы услуг</h1>
      </div>

      <!-- Services Table -->
      <div class="admin-card">
        <h2 class="admin-card__title">Все разделы (<%= content.services.length %>)</h2>

        <% if (content.services.length === 0) { %>
          <p style="color: #999; font-size: 0.9rem;">Нет разделов услуг. Добавьте первый раздел ниже.</p>
        <% } else { %>
          <table class="admin-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Название</th>
                <th>Короткое имя</th>
                <th>Позиций</th>
                <th>Действия</th>
              </tr>
            </thead>
            <tbody>
              <% content.services.forEach(function(s, i) { %>
                <tr>
                  <td style="color: #bbb; font-size: 0.82rem;"><%= i + 1 %></td>
                  <td>
                    <span class="admin-table__name"><%= s.name %></span>
                  </td>
                  <td>
                    <span class="admin-table__short"><%= s.shortName %></span>
                  </td>
                  <td>
                    <span class="admin-table__count"><%= s.items ? s.items.length : 0 %></span>
                  </td>
                  <td>
                    <div class="admin-table__actions">
                      <button type="button" class="admin-table__btn admin-table__btn--reorder" onclick="reorderService('<%= s.slug %>', 'up')" <% if (i === 0) { %>disabled<% } %>>▲</button>
                      <button type="button" class="admin-table__btn admin-table__btn--reorder" onclick="reorderService('<%= s.slug %>', 'down')" <% if (i === content.services.length - 1) { %>disabled<% } %>>▼</button>
                      <a href="/admin/services/<%= s.slug %>" class="admin-table__btn admin-table__btn--edit">Редактировать</a>
                      <form method="POST" action="/admin/services/<%= s.slug %>/delete" style="margin:0;"
                            onsubmit="return confirm('Удалить раздел &laquo;<%= s.name %>&raquo;? Это действие нельзя отменить.');">
                        <button type="submit" class="admin-table__btn admin-table__btn--delete">Удалить</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- Add New Service -->
      <div class="admin-card">
        <h2 class="admin-card__title">Добавить новый раздел</h2>

        <form method="POST" action="/admin/services-add" class="admin-form">
          <div class="admin-form__row">
            <div class="admin-form__group">
              <label class="admin-form__label" for="newName">Название</label>
              <input class="admin-form__input" type="text" id="newName" name="name" required placeholder="Полное название раздела">
            </div>
            <div class="admin-form__group">
              <label class="admin-form__label" for="newShortName">Короткое название</label>
              <input class="admin-form__input" type="text" id="newShortName" name="shortName" required placeholder="Для меню навигации">
            </div>
            <div class="admin-form__group">
              <label class="admin-form__label" for="newSlug">URL-slug</label>
              <input class="admin-form__input" type="text" id="newSlug" name="slug" required placeholder="nazvanie-latinicey"
                     pattern="[a-z0-9\-]+" title="Только строчные латинские буквы, цифры и дефисы">
              <div class="admin-form__hint">Только латиница, цифры и дефисы (например: novaya-usluga)</div>
            </div>
          </div>
          <button type="submit" class="admin-form__btn admin-form__btn--small">Добавить раздел</button>
        </form>
      </div>

    </main>
  </div>

  <script>
    // Auto-generate slug from name
    document.getElementById('newName').addEventListener('input', function() {
      var slug = this.value
        .toLowerCase()
        .replace(/[а-яё]/g, function(ch) {
          var map = {
            'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo','ж':'zh','з':'z','и':'i',
            'й':'y','к':'k','л':'l','м':'m','н':'n','о':'o','п':'p','р':'r','с':'s','т':'t',
            'у':'u','ф':'f','х':'h','ц':'ts','ч':'ch','ш':'sh','щ':'sch','ъ':'','ы':'y',
            'ь':'','э':'e','ю':'yu','я':'ya'
          };
          return map[ch] || ch;
        })
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
      document.getElementById('newSlug').value = slug;
    });

    function reorderService(slug, direction) {
      fetch('/admin/services-reorder', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ slug, direction })
      })
      .then(response => response.json())
      .then(data => {
        if (data.ok) {
          location.reload();
        } else {
          alert('Не удалось переместить раздел');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Ошибка при перемещении раздела');
      });
    }
  </script>
</body>
</html>
