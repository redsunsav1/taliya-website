<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — Тали.Я (Tali.Ya) Админ-панель</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #f8f5f2 0%, #ede4df 100%);
      font-family: 'Montserrat', sans-serif;
    }
    .login-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(89, 99, 65, 0.12);
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      text-align: center;
    }
    .login-card__heading {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: #596341;
      margin: 0 0 8px;
    }
    .login-card__sub {
      font-size: 0.85rem;
      color: #999;
      margin: 0 0 32px;
    }
    .login-card__error {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
      border-radius: 8px;
      padding: 10px 16px;
      font-size: 0.85rem;
      margin-bottom: 20px;
    }
    .login-card__group {
      margin-bottom: 20px;
      text-align: left;
    }
    .login-card__label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: #555;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .login-card__input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 0.95rem;
      font-family: 'Montserrat', sans-serif;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .login-card__input:focus {
      outline: none;
      border-color: #596341;
      box-shadow: 0 0 0 3px rgba(89, 99, 65, 0.1);
    }
    .login-card__btn {
      width: 100%;
      padding: 14px;
      background: #596341;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      font-family: 'Montserrat', sans-serif;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 8px;
    }
    .login-card__btn:hover {
      background: #7a4f5c;
    }
    .login-card__footer {
      margin-top: 24px;
      font-size: 0.8rem;
      color: #aaa;
    }
    .login-card__footer a {
      color: #596341;
      text-decoration: none;
    }
    .login-card__footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <div class="login-card">
    <h1 class="login-card__heading">Тали.Я (Tali.Ya) &mdash; Админ-панель</h1>
    <p class="login-card__sub">Войдите для управления сайтом</p>

    <% if (error) { %>
      <div class="login-card__error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="login-card__group">
        <label class="login-card__label" for="username">Логин</label>
        <input class="login-card__input" type="text" id="username" name="username" required autofocus placeholder="Введите логин">
      </div>

      <div class="login-card__group">
        <label class="login-card__label" for="password">Пароль</label>
        <input class="login-card__input" type="password" id="password" name="password" required placeholder="Введите пароль">
      </div>

      <button type="submit" class="login-card__btn">Войти</button>
    </form>

    <div class="login-card__footer">
      <a href="/">&larr; Вернуться на сайт</a>
    </div>
  </div>

</body>
</html>
